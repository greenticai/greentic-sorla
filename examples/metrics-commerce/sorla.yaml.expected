package:
  name: metrics-commerce
  version: 0.1.0
  i18n_key: examples.metrics_commerce.package
roles:
  - id: admin
    i18n_key: examples.metrics_commerce.roles.admin
    label: Admin
    description: "Full administrative access to commerce metric records."
    grants:
      - "records.*"
      - "agent_endpoints.*"
  - id: analytics
    i18n_key: examples.metrics_commerce.roles.analytics
    label: Analytics
    description: "Read metric source records and dashboards."
    grants:
      - "records.*.read"
      - metrics.read
  - id: marketing_ops
    i18n_key: examples.metrics_commerce.roles.marketing_ops
    label: "Marketing operations"
    description: "Record campaign, visitor, and click activity."
    grants:
      - "records.campaign.*"
      - records.visitor.create
      - records.click.create
  - id: finance
    i18n_key: examples.metrics_commerce.roles.finance
    label: Finance
    description: "Record payments and costs for revenue reporting."
    grants:
      - "records.payment.*"
      - "records.cost_entry.*"
      - records.order.read
