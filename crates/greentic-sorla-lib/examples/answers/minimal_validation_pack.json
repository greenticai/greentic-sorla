{
  "schema_version": "0.4",
  "flow": "create",
  "output_dir": "target/greentic-sorla-minimal-validation-pack-example",
  "package": {
    "name": "minimal-validation-sor",
    "version": "0.1.0"
  },
  "records": {
    "default_source": "native"
  },
  "events": {
    "enabled": true
  },
  "projections": {
    "mode": "current-state"
  },
  "migrations": {
    "compatibility": "additive"
  },
  "agent_endpoints": {
    "enabled": false
  },
  "output": {
    "include_agent_tools": false
  }
}
